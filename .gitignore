# Local infrastructure
/conf/
/logs/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log

# Secrets / env
.env
.env.local
.env.*.local
*.key
*.pem

# Archives / backups / dumps
*.zip
*.tar
*.tar.gz
*.gz
*.sql

# Node / build artifacts
node_modules/
dist/
build/
coverage/

# Ignore everything under app by default
/app/**

# Re-include the path down to wp-content
!/app/
!/app/public/
!/app/public/wp-content/
!/app/public/wp-content/themes/
!/app/public/wp-content/plugins/

# Ignore everything inside themes/plugins by default
/app/public/wp-content/themes/**
/app/public/wp-content/plugins/**

# Keep only your custom theme and pba plugins
!/app/public/wp-content/themes/pba-theme/
!/app/public/wp-content/themes/pba-theme/**

!/app/public/wp-content/plugins/pba-site-app/
!/app/public/wp-content/plugins/pba-site-app/**

!/app/public/wp-content/plugins/pba-supabase-connector/
!/app/public/wp-content/plugins/pba-supabase-connector/**

!/app/public/wp-content/plugins/pba-custom-roles/
!/app/public/wp-content/plugins/pba-custom-roles/**

# Ignore generated WP content
/app/public/wp-content/uploads/
/app/public/wp-content/uploads/**
/app/public/wp-content/cache/
/app/public/wp-content/cache/**
/app/public/wp-content/upgrade/
/app/public/wp-content/upgrade/**
/app/public/wp-content/backup-db/
/app/public/wp-content/backup-db/**
/app/public/wp-content/ai1wm-backups/
/app/public/wp-content/ai1wm-backups/**
/app/public/wp-content/debug.log
/app/public/wp-content/advanced-cache.php
/app/public/wp-content/object-cache.php
/app/public/wp-content/mu-plugins/
/app/public/wp-content/mu-plugins/**

# Ignore accidental core/runtime files
/app/public/wp-admin/
/app/public/wp-admin/**
/app/public/wp-includes/
/app/public/wp-includes/**
/app/public/index.php
/app/public/license.txt
/app/public/readme.html
/app/public/xmlrpc.php
/app/public/wp-*.php